      "listening_skills": "Can understand orally presented materials such as coherent conversations, news reports, and lectures, spoken at natural speed in a wide variety of settings.",
      "reading_skills": "Can read writings with logical complexity and/or abstract ideas on a broad range of topics, such as newspaper editorials and critiques."
    },
    "grammar": [
      {
        "pattern": "〜なりに / 〜なりの",
        "explanation": "In a way that is appropriate to / In one's own way.",
        "example": "子供なりに、一生懸命考えています。",
        "translation": "In his own way, the child is thinking as hard as he can."
      },
      {
        "pattern": "〜をもって",
        "explanation": "By means of / With / As of (formal/literary).",
        "example": "本日をもって、受付を終了いたします。",
        "translation": "As of today, we will stop accepting applications."
      },
      {
        "pattern": "〜がゆえに",
        "explanation": "Because of / Due to (literary/classical style).",
        "example": "有名人ゆえに、自由な行動ができない。",
        "translation": "Because he is a celebrity, he cannot act freely."
      },
      {
        "pattern": "〜まじき",
        "explanation": "Should not / Must not / Unpardonable (formal).",
        "example": "それは、警察官としてあるまじき行為だ。",
        "translation": "That is an act that should not be committed by a police officer."
      },
      {
        "pattern": "〜にかたくない",
        "explanation": "Not difficult to (usually 'imagine' or 'understand').",
        "example": "彼の落胆ぶりは、察するに難くない。",
        "translation": "It is not difficult to imagine how discouraged he is."
      },
      {
        "pattern": "〜極まりない",
        "explanation": "Extremely / There is no limit to (negative connotation).",
        "example": "彼の態度は、失礼極まりない。",
        "translation": "His attitude is extremely rude."
      },
      {
        "pattern": "〜ずにはおかない",
        "explanation": "Will certainly do / Cannot help but...",
        "example": "その映画は、見る人を感動させずにはおかない。",
        "translation": "That movie never fails to move those who see it."
      }
    ],
