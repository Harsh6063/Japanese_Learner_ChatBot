  "N2_Complete_Syllabus": {
    "description": "The ability to understand Japanese used in everyday situations, and in a variety of circumstances to a certain degree. This is the standard for working in a Japanese company.",
    "requirements": {
      "kanji": "Approximately 1,000 (350+ new after N3)",
      "vocabulary": "Approximately 6,000 words",
      "listening_skills": "Can understand orally presented materials such as coherent conversations and news reports, spoken at nearly natural speed.",
      "reading_skills": "Can read and understand articles and commentaries written about various topics, such as newspapers and magazines."
    },
    "grammar": [
      {
        "pattern": "〜ことだ",
        "explanation": "Used when giving a strong suggestion or advice (Should / The thing is...).",
        "example": "日本語が上手になりたければ、毎日話すことだ。",
        "translation": "If you want to become good at Japanese, you should speak it every day."
      },
      {
        "pattern": "〜おかげで / 〜せいで",
        "explanation": "Thanks to (positive) / Because of (negative).",
        "example": "先生のおかげで、合格できました。",
        "translation": "Thanks to my teacher, I was able to pass."
      },
      {
        "pattern": "〜に際して",
        "explanation": "On the occasion of / At the time of (formal).",
        "example": "日本へ行くに際して、ビザを申請した。",
        "translation": "On the occasion of going to Japan, I applied for a visa."
      },
      {
        "pattern": "〜に基づいて",
        "explanation": "Based on / On the basis of.",
        "example": "この映画は、事実に基いて作られています。",
        "translation": "This movie is based on a true story."
      },
      {
        "pattern": "〜ぬきで",
        "explanation": "Without / Leaving out.",
        "example": "冗談抜きで、真面目に考えてください。",
        "translation": "Jokes aside (leaving out jokes), please think seriously."
      },
      {
        "pattern": "〜うちに / 〜ないうちに",
        "explanation": "While... (before something else happens).",
        "example": "暗くならないうちに、帰りましょう。",
        "translation": "Let's go home before it gets dark."
      },
      {
        "pattern": "〜たびに",
        "explanation": "Whenever / Every time (something happens).",
        "example": "その写真を見るたびに、家族を思い出す。",
        "translation": "Every time I look at that photo, I remember my family."
      }
    ],
