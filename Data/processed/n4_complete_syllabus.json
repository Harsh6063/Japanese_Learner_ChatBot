{
  "N4_Complete_Syllabus": {
    "description": "The ability to understand Japanese used in everyday situations. This is the 'Daily Life' fluency level.",
    "requirements": {
      "kanji": "Approximately 300 (200 new after N5)",
      "vocabulary": "Approximately 1,500 words",
      "listening_skills": "Can understand conversations encountered in daily life and follow their contents to a large degree.",
      "reading_skills": "Can read and understand passages on familiar daily topics written with basic vocabulary and kanji."
    },
    "grammar": [
      {
        "pattern": "〜ことができる",
        "explanation": "Expresses ability or possibility (Can do).",
        "example": "日本料理を作ることができます。",
        "translation": "I can cook Japanese food."
      },
      {
        "pattern": "〜たことがある",
        "explanation": "Expresses past experience (Have done before).",
        "example": "富士山に登ったことがあります。",
        "translation": "I have climbed Mt. Fuji before."
      },
      {
        "pattern": "〜すぎる",
        "explanation": "Expresses excessiveness (Too much).",
        "example": "お酒を飲みすぎました。",
        "translation": "I drank too much sake."
      },
      {
        "pattern": "〜ほうがいい",
        "explanation": "Used to give advice (Had better do).",
        "example": "早く寝たほうがいいですよ。",
        "translation": "You had better go to sleep early."
      },
      {
        "pattern": "〜といわれる",
        "explanation": "Passive form (To be told).",
        "example": "先生に褒められました。",
        "translation": "I was praised by the teacher."
      },
      {
        "pattern": "〜つもりだ",
        "explanation": "Expresses intention (Plan to do).",
        "example": "来年、日本へ行くつもりです。",
        "translation": "I plan to go to Japan next year."
      },
      {
        "pattern": "〜みたいだ / 〜そうだ",
        "explanation": "Expresses appearance or hearsay (Seems like / Looks like).",
        "example": "雨が降りそうです。",
        "translation": "It looks like it will rain."
      }
    ],
