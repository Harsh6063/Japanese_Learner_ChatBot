{
  "N3_Complete_Syllabus": {
    "description": "The ability to understand Japanese used in specific everyday situations to a certain degree. This level bridges the gap between basic and advanced Japanese.",
    "requirements": {
      "kanji": "Approximately 650 (350 new after N4)",
      "vocabulary": "Approximately 3,000 words",
      "listening_skills": "Can understand coherent conversations in everyday situations, spoken at near-natural speed.",
      "reading_skills": "Can read and understand passages on specific topics, headlines, and can grasp the summary of slightly difficult writings."
    },
    "grammar": [
      {
        "pattern": "〜うちに",
        "explanation": "While / Before a change happens (while the state is still current).",
        "example": "忘れないうちに、メモしておきます。",
        "translation": "I'll make a note while I still remember (before I forget)."
      },
      {
        "pattern": "〜べきだ",
        "explanation": "Should do / Must do (moral obligation or strong advice).",
        "example": "約束は守るべきだ。",
        "translation": "One should keep their promises."
      },
      {
        "pattern": "〜によって",
        "explanation": "Due to / By / Depending on.",
        "example": "人によって考え方が違います。",
        "translation": "Way of thinking differs depending on the person."
      },
      {
        "pattern": "〜たとたん（に）",
        "explanation": "Just as / The moment something happened.",
        "example": "窓を開けたとたん、強い風が入ってきた。",
        "translation": "The moment I opened the window, a strong wind came in."
      },
      {
        "pattern": "〜はずだ",
        "explanation": "Expectation / It should be that...",
        "example": "彼はもうすぐ来るはずです。",
        "translation": "He should be here any minute."
      },
      {
        "pattern": "〜にかわって",
        "explanation": "Instead of / On behalf of.",
        "example": "父にかわって、私が挨拶します。",
        "translation": "I will give the greeting on behalf of my father."
      },
      {
        "pattern": "〜せいか",
        "explanation": "Perhaps because of (usually for a negative reason).",
        "example": "風邪のせいか、頭が痛いです。",
        "translation": "Perhaps because of a cold, my head hurts."
      }
    ],
