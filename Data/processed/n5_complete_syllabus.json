    "grammar": [
      {
        "pattern": "〜は〜です",
        "explanation": "A is B. 'は' (pronounced 'wa') marks the topic.",
        "example": "私は学生です。",
        "translation": "I am a student."
      },
      {
        "pattern": "〜を",
        "explanation": "Object marker. Indicates what the verb is acting upon.",
        "example": "パンを食べます。",
        "translation": "I eat bread."
      },
      {
        "pattern": "〜に/へ",
        "explanation": "Directional particles indicating destination.",
        "example": "日本に行きます。",
        "translation": "I am going to Japan."
      },
      {
        "pattern": "〜てください",
        "explanation": "Polite request.",
        "example": "座ってください。",
        "translation": "Please sit down."
      },
      {
        "pattern": "〜ている",
        "explanation": "Present continuous (currently doing).",
        "example": "テレビを見ています。",
        "translation": "I am watching TV."
      }
    ],
    "study_plan": [
      "1. Master Hiragana and Katakana (Reading and Writing).",
      "2. Memorize the 100 N5 Kanji and their common readings.",
      "3. Build a vocabulary of 800 words using flashcards (Anki).",
      "4. Practice verb conjugations (Masu-form, Te-form, Dictionary-form).",
      "5. Listen to N5-level audio daily to improve ear for particles.",
      "6. Take mock exams to manage time for the Reading and Listening sections."
    ]
